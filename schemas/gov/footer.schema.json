{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ivds.dev/schemas/gov/footer.schema.json",
  "title": "Gov Footer Sections",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "title", "links"],
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "title": {
        "type": "object",
        "required": ["fr", "en"],
        "properties": {
          "fr": { "type": "string", "minLength": 1 },
          "en": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "links": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "label", "href"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "href": { "type": "string", "minLength": 1 },
            "label": {
              "type": "object",
              "required": ["fr", "en"],
              "properties": {
                "fr": { "type": "string", "minLength": 1 },
                "en": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  }
}
