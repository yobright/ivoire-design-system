{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ivds.dev/schemas/gov/nav.schema.json",
  "title": "Gov Navigation Items",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "label", "href"],
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "href": { "type": "string", "minLength": 1 },
      "label": {
        "type": "object",
        "required": ["fr", "en"],
        "properties": {
          "fr": { "type": "string", "minLength": 1 },
          "en": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "children": {
        "$ref": "#"
      }
    },
    "additionalProperties": false
  }
}
