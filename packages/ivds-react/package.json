{
  "name": "@ivds/react",
  "version": "1.0.0",
  "description": "React components for the Ivoire Design System",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "require": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./components": {
      "import": "./lib/index.js",
      "require": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./components/*": {
      "import": "./lib/components/*/index.js",
      "require": "./lib/components/*/index.js",
      "types": "./lib/components/*/index.d.ts"
    },
    "./theme": {
      "import": "./lib/theme/index.js",
      "require": "./lib/theme/index.js",
      "types": "./lib/theme/index.d.ts"
    },
    "./hooks": {
      "import": "./lib/hooks/index.js",
      "require": "./lib/hooks/index.js",
      "types": "./lib/hooks/index.d.ts"
    },
    "./gov": {
      "import": "./lib/gov/index.js",
      "require": "./lib/gov/index.js",
      "types": "./lib/gov/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf lib/ && yarn build:cjs && yarn build:types",
    "build:types": "tsc --declaration --emitDeclarationOnly --declarationMap --outDir lib",
    "build:cjs": "tsc --module commonjs --outDir lib --declaration false --sourceMap false",
    "build:esm": "echo 'ESM build skipped for now'",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts,.tsx --ignore-pattern '**/*.stories.ts' --ignore-pattern '**/*.stories.tsx'",
    "lint:fix": "eslint src --ext .ts,.tsx --ignore-pattern '**/*.stories.ts' --ignore-pattern '**/*.stories.tsx' --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:visual": "chromatic --exit-zero-on-changes",
    "test:visual:local": "playwright test --config=playwright.config.ts",
    "test:visual:update": "playwright test --config=playwright.config.ts --update-snapshots",
    "test:a11y": "test-runner --config-dir .storybook",
    "test:all": "yarn test && yarn test:visual && yarn test:a11y",
    "clean": "rimraf lib/ coverage/",
    "prepublishOnly": "yarn clean && yarn build && yarn test",
    "storybook": "storybook dev -p 6008 --quiet",
    "build-storybook": "storybook build --loglevel error"
  },
  "peerDependencies": {
    "@ivds/core": "^1.0.0",
    "@ivds/design-tokens": "^1.0.0",
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "@storybook/addon-a11y": "^7.6.0",
    "@storybook/addon-essentials": "^7.6.0",
    "@storybook/addon-measure": "^7.6.0",
    "@storybook/addon-outline": "^7.6.0",
    "@storybook/react": "^7.6.0",
    "@storybook/react-vite": "^7.6.0",
    "@storybook/test-runner": "^0.15.0",
    "@testing-library/dom": "^9.3.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "axe-playwright": "^1.2.0",
    "chromatic": "^10.0.0",
    "eslint": "^8.50.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "playwright": "^1.40.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.0",
    "storybook": "^7.6.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.2.0",
    "vite": "^4.5.0"
  },
  "keywords": [
    "design-system",
    "react",
    "components",
    "ui",
    "typescript",
    "ivds",
    "ivoire"
  ],
  "author": "IVDS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yobright/ivoire-design-system.git",
    "directory": "packages/ivds-react"
  },
  "bugs": {
    "url": "https://github.com/yobright/ivoire-design-system/issues"
  },
  "homepage": "https://yobright.github.io/ivoire-design-system/react",
  "engines": {
    "node": ">=22.13.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/yobright"
  }
}
