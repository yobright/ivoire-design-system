{
  "name": "@ivds/core",
  "version": "1.0.0",
  "description": "Core styles for the Ivoire Design System",
  "main": "lib/base.css",
  "style": "lib/all.css",
  "files": [
    "lib",
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "style": "./lib/all.css",
      "default": "./lib/all.css"
    },
    "./all": {
      "style": "./lib/all.css",
      "default": "./lib/all.css"
    },
    "./all.min": {
      "style": "./lib/all.min.css",
      "default": "./lib/all.min.css"
    },
    "./base": {
      "style": "./lib/base.css",
      "default": "./lib/base.css"
    },
    "./base.min": {
      "style": "./lib/base.min.css",
      "default": "./lib/base.min.css"
    },
    "./components": {
      "style": "./lib/components/all.css",
      "default": "./lib/components/all.css"
    },
    "./components.min": {
      "style": "./lib/components/all.min.css",
      "default": "./lib/components/all.min.css"
    },
    "./components/*": {
      "style": "./lib/components/*.css",
      "default": "./lib/components/*.css"
    },
    "./utils": {
      "style": "./lib/utils/utils.css",
      "default": "./lib/utils/utils.css"
    },
    "./utils.min": {
      "style": "./lib/utils/utils.min.css",
      "default": "./lib/utils/utils.min.css"
    },
    "./utils-only": {
      "style": "./lib/utils-only.css",
      "default": "./lib/utils-only.css"
    },
    "./utils-only.min": {
      "style": "./lib/utils-only.min.css",
      "default": "./lib/utils-only.min.css"
    },
    "./utils/*": {
      "style": "./lib/utils/*.css",
      "default": "./lib/utils/*.css"
    },
    "./icons": {
      "style": "./lib/icons/icons.css",
      "default": "./lib/icons/icons.css"
    },
    "./icons.min": {
      "style": "./lib/icons/icons.min.css",
      "default": "./lib/icons/icons.min.css"
    },
    "./icons/*": {
      "style": "./lib/icons/*.css",
      "default": "./lib/icons/*.css"
    },
    "./gov": {
      "style": "./lib/gov/gov.css",
      "default": "./lib/gov/gov.css"
    },
    "./gov.min": {
      "style": "./lib/gov/gov.min.css",
      "default": "./lib/gov/gov.min.css"
    },
    "./gov/*": {
      "style": "./lib/gov/*.css",
      "default": "./lib/gov/*.css"
    },
    "./variables": {
      "style": "./lib/variables/variables.css",
      "default": "./lib/variables/variables.css"
    },
    "./variables.min": {
      "style": "./lib/variables/variables.min.css",
      "default": "./lib/variables/variables.min.css"
    },
    "./src/*": "./src/*"
  },
  "scripts": {
    "generate-icons": "node scripts/generateIcons.js",
    "build": "rimraf lib/ && yarn generate-icons && yarn lint:styles && yarn postcss-build && yarn css-to-ts && yarn copy-scss-files && yarn copy-scss-utils && yarn cssToScss",
    "build:prod": "NODE_ENV=production SASS_SILENCE_DEPRECATIONS=legacy-js-api,import yarn build",
    "postcss-build": "postcss 'src/**/[!_]*.(css|scss)' --base src -d lib --ext .css && postcss 'src/**/[!_]*.(css|scss)' --base src -d lib --ext 'min.css' --env 'minify'",
    "postcss-watch": "postcss 'src/**/*.(css|scss)' --base src -d lib --watch",
    "cssToScss": "node scripts/cssToScss.js",
    "copy-scss-files": "node copyFiles -source 'src/components/**/_*.scss' -target 'lib/components' -v",
    "copy-scss-utils": "node copyFiles -source 'src/utils/**/_*.scss' -target 'lib/utils' -v",
    "css-to-ts": "node cssToImportableString -directory 'lib/components/**/*.min.css' -targetFiles 'modal.min.css,notification.min.css'",
    "lint": "yarn lint:styles",
    "lint:styles": "stylelint \"src/**/*.(css|scss)\" --ignore-pattern \"src/**/__tests__/*.scss\"",
    "lint:fix": "stylelint \"src/**/*.(css|scss)\" --ignore-pattern \"src/**/__tests__/*.scss\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf lib/ coverage/ storybook-static/",
    "prepublishOnly": "yarn clean && yarn build:prod && yarn test",
    "start": "yarn storybook",
    "scss-tests": "yarn jest",
    "storybook": "storybook dev -p 6007 --quiet",
    "build-storybook": "storybook build --loglevel error",
    "size": "bundlesize"
  },
  "peerDependencies": {
    "@ivds/design-tokens": "^1.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.4",
    "@csstools/postcss-sass": "^5.1.1",
    "@storybook/addon-a11y": "^7.6.0",
    "@storybook/addon-backgrounds": "^7.6.0",
    "@storybook/addon-docs": "^7.6.0",
    "@storybook/addon-essentials": "^7.6.0",
    "@storybook/addon-measure": "^7.6.0",
    "@storybook/addon-outline": "^7.6.0",
    "@storybook/addon-storysource": "^7.6.0",
    "@storybook/addon-viewport": "^7.6.0",
    "@storybook/addons": "^7.6.0",
    "@storybook/builder-webpack5": "^7.6.0",
    "@storybook/html": "^7.6.0",
    "@storybook/html-webpack5": "^7.6.0",
    "@storybook/preset-scss": "^1.0.3",
    "autoprefixer": "^10.4.20",
    "babel-jest": "^29.7.0",
    "bundlesize": "^0.18.1",
    "copyfiles": "^2.4.1",
    "css-loader": "^6.11.0",
    "cssnano": "^6.0.0",
    "glob": "^10.3.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.0",
    "postcss-classes-to-mixins": "^3.0.1",
    "postcss-cli": "^10.0.0",
    "postcss-import": "^15.1.0",
    "postcss-inline-svg": "^6.0.0",
    "postcss-preset-env": "^9.0.0",
    "postcss-scss": "^4.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^5.0.0",
    "sass": "^1.77.8",
    "sass-loader": "^14.2.1",
    "sass-true": "^8.0.0",
    "storybook": "^7.6.0",
    "style-loader": "^3.3.4",
    "stylelint": "^15.1.0",
    "stylelint-config-css-modules": "^4.4.0",
    "stylelint-config-standard": "^30.0.1",
    "stylelint-config-standard-scss": "^7.0.1",
    "stylelint-order": "^6.0.4"
  },
  "keywords": [
    "design-system",
    "css",
    "scss",
    "components",
    "ui",
    "ivds",
    "ivoire"
  ],
  "author": "IVDS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yobright/ivoire-design-system.git",
    "directory": "packages/ivds-core"
  },
  "bugs": {
    "url": "https://github.com/yobright/ivoire-design-system/issues"
  },
  "homepage": "https://yobright.github.io/ivoire-design-system",
  "engines": {
    "node": ">=22.13.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/yobright"
  },
  "bundlesize": [
    {
      "path": "./lib/all.css",
      "maxSize": "80 kB"
    },
    {
      "path": "./lib/all.min.css",
      "maxSize": "55 kB"
    },
    {
      "path": "./lib/components/all.css",
      "maxSize": "35 kB"
    },
    {
      "path": "./lib/components/all.min.css",
      "maxSize": "18 kB"
    }
  ]
}
